# ----------------------------------------------------------------------------
# ANIMUS — Supabase Edge Function secrets
# ----------------------------------------------------------------------------
# Set in production with:
#   supabase secrets set --env-file supabase/functions/.env
# Do NOT commit a real .env to git. This file is the schema only.
# ----------------------------------------------------------------------------

# --- Supabase (auto-injected in the cloud — set locally for `supabase functions serve`)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- iCount payments (icount-create-payment, icount-payment-webhook)
# REQUIRED. Shared secret iCount echoes back in the X-iCount-Secret header on webhook POSTs.
# If unset, the webhook will accept any caller (DEV ONLY — set this in production).
ICOUNT_WEBHOOK_SECRET=

# REQUIRED for the payment-create + docnum-sync paths.
ICOUNT_API_TOKEN=

# --- ShineOn fulfillment (icount-payment-webhook)
# REQUIRED. Without this, the webhook will mark orders paid but skip ShineOn submission
# (response field: shineon_skipped, reason: "missing_shineon_key").
SHINEON_API_KEY=

# Shared secret authenticating ShineOn's shipment callback. The iCount webhook appends
# it to shipment_notification_url as ?secret=...; shineon-shipment-notification rejects
# mismatches. If unset, the callback is unauthenticated (any caller can forge a "shipped"
# event) - set this in production.
SHINEON_WEBHOOK_SECRET=

# --- Email (send-campaign-email, send-transactional-email, process-email-queue)
# REQUIRED. All outbound email sends directly via the Resend API (api.resend.com).
# Get the key from the Resend dashboard → API Keys.
# NOTE: auth emails (admin signup confirm / password reset) are handled natively by
# Supabase Auth, not this key.
RESEND_API_KEY=
# Optional. Overrides the From address for every outbound email. Use a verified Resend
# sender. Defaults to "ANIMUS <onboarding@resend.dev>" (Resend test domain) until
# animuswaves.com is verified in Resend, after which set e.g. "ANIMUS <noreply@animuswaves.com>".
RESEND_FROM=ANIMUS <onboarding@resend.dev>

# --- Soul Engine (generate-soul-waveform)
# Optional. Used as the base for soul_page_url. Defaults to https://animuswaves.com.
SOUL_PAGE_BASE_URL=https://animuswaves.com
