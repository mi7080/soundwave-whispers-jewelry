# ----------------------------------------------------------------------------
# ANIMUS — Supabase Edge Function secrets
# ----------------------------------------------------------------------------
# Set in production with:
#   supabase secrets set --env-file supabase/functions/.env
# Do NOT commit a real .env to git. This file is the schema only.
# ----------------------------------------------------------------------------

# --- Supabase (auto-injected in the cloud — set locally for `supabase functions serve`)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- iCount payments (icount-create-payment, icount-payment-webhook, icount-find-docnum, sync-icount-order)
# REQUIRED. Shared secret iCount echoes back in the X-iCount-Secret header on webhook POSTs.
# If unset, the webhook will accept any caller (DEV ONLY — set this in production).
ICOUNT_WEBHOOK_SECRET=

# REQUIRED for the payment-create + docnum-sync paths.
ICOUNT_API_TOKEN=

# --- ShineOn fulfillment (icount-payment-webhook)
# REQUIRED. Without this, the webhook will mark orders paid but skip ShineOn submission
# (response field: shineon_skipped, reason: "missing_shineon_key").
SHINEON_API_KEY=

# --- Email (send-campaign-email, send-transactional-email, process-email-queue, auth-email-hook)
# Both providers are supported; LOVABLE_* is the primary path, RESEND_API_KEY is for
# campaign sends.
LOVABLE_API_KEY=
LOVABLE_SEND_URL=
RESEND_API_KEY=

# --- Soul Engine (generate-soul-waveform)
# Optional. Used as the base for soul_page_url. Defaults to https://animuswave.com.
SOUL_PAGE_BASE_URL=https://animuswave.com
