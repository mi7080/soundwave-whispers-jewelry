# ----------------------------------------------------------------------------
# Frontend (Vite) environment variables
# ----------------------------------------------------------------------------
# Copy to `.env` and fill in. These are exposed to the browser by Vite
# (VITE_ prefix), so use only public/publishable values here — never secrets.
# Values come from the Supabase dashboard: Project Settings -> API.
# Backend secrets live separately in supabase/functions/.env.example.
# ----------------------------------------------------------------------------

# Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Supabase anon / publishable key (safe to expose to the browser)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase project ref/id, e.g. abcdefgh
VITE_SUPABASE_PROJECT_ID=

# PostHog analytics (public values — safe to expose to the browser)
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
